# ============================================================
# Django core
# ============================================================
# Unique secret key — generate a fresh value for production.
SECRET_KEY=change-me-in-production
# Debug mode — must be False in production.
DEBUG=True
# Comma-separated list of allowed hosts.
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# Database (external / custom)
# ============================================================
# Leave the DB_* variables below commented to use local SQLite (zero-config dev).
# Uncomment and fill them in to connect to your external database.
#
# Backend: postgresql | mysql | sqlite3
# DB_ENGINE=postgresql
# Database name.
# DB_NAME=your_database_name
# Database user.
# DB_USER=your_database_user
# Database password.
# DB_PASSWORD=your_database_password
# Host (domain or IP of your external database).
# DB_HOST=your-db-host.example.com
# Port (PostgreSQL: 5432, MySQL: 3306).
# DB_PORT=5432
# Persistent connection lifetime, seconds (0 = close after each request).
# DB_CONN_MAX_AGE=60
#
# --- SSL / TLS (PostgreSQL) — managed/cloud databases usually require this ---
# Modes: disable | require | verify-ca | verify-full  (default: require)
# DB_SSL_MODE=require
# Absolute path to the CA certificate (only for verify-ca / verify-full).
# DB_SSL_ROOT_CERT=/absolute/path/to/ca.pem
#
# --- Alternative: single connection string ---
# If set, DATABASE_URL OVERRIDES all DB_* variables above.
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ============================================================
# Media storage — S3-compatible object storage (AWS S3 / Cloudflare R2 / B2)
# ============================================================
# Render.com's filesystem is ephemeral, so user-uploaded media MUST live in
# object storage. Leave AWS_STORAGE_BUCKET_NAME blank/commented to use local
# filesystem media (zero-config dev). Set the vars below to enable S3/R2.
#
# Access credentials (never commit real keys).
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Bucket name — setting this activates the S3 backend.
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# Region (AWS: e.g. eu-central-1; Cloudflare R2: use "auto").
# AWS_S3_REGION_NAME=auto
#
# --- Endpoint (required for Cloudflare R2 / Backblaze; OMIT for pure AWS S3) ---
# Cloudflare R2 example:
# AWS_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
#
# --- Optional CDN / custom domain that serves the bucket publicly ---
# AWS_S3_CUSTOM_DOMAIN=cdn.example.com

# ============================================================
# Email
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com
INQUIRY_RECIPIENT_EMAIL=info@example.com
